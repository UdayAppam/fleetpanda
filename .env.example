# Copy to .env to override defaults.

# --- Local full-stack dev (json-server backend) ---
# Base URL of the mock API (json-server via server.js). Used by `npm run dev:all`.
VITE_API_URL=http://localhost:4000
# Pins the app's "today" to the seed date so a fresh clone shows an active shift.
VITE_DEMO_DATE=2025-11-24

# --- Serverless demo mode (in-browser MSW, no backend) ---
# Set VITE_MOCK=true to run the API in the browser (see src/mocks/browser.ts). This is what
# the Netlify deploy uses (configured in netlify.toml). Locally: `npm run dev:mock`.
# In this mode leave VITE_API_URL unset (requests are same-origin, intercepted by MSW) and
# pin VITE_DEMO_DATE=2026-07-10 to match the frozen seed snapshot.
# VITE_MOCK=true
