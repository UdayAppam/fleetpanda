{
  "name": "fleetpanda",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "mock": "node server.js",
    "dev:all": "concurrently -n web,api -c cyan,magenta \"npm:dev\" \"npm:mock\"",
    "dev:mock": "VITE_MOCK=true vite",
    "seed": "node seed.js",
    "seed:snapshot": "SEED_DATE=2026-07-10 node seed.js && cp db.json src/mocks/db.seed.json",
    "build": "tsc -b && vite build",
    "build:mock": "VITE_MOCK=true VITE_DEMO_DATE=2026-07-10 npm run build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext ts,tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource/barlow-semi-condensed": "^5.0.13",
    "@fontsource/ibm-plex-mono": "^5.0.13",
    "@fontsource/ibm-plex-sans": "^5.0.20",
    "@hookform/resolvers": "^3.9.1",
    "@reduxjs/toolkit": "^2.3.0",
    "@tanstack/react-query": "^5.59.16",
    "date-fns": "^4.1.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.454.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.1",
    "react-leaflet": "^4.2.1",
    "react-redux": "^9.1.2",
    "react-router-dom": "^6.27.0",
    "redux-persist": "^6.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.2",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/leaflet": "^1.9.14",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "^2.1.4",
    "concurrently": "^9.0.1",
    "jsdom": "^25.0.1",
    "json-server": "0.17.4",
    "msw": "^2.6.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}